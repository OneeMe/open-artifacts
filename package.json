{
  "name": "open-artifacts",
  "version": "0.1.0",
  "description": "Open Artifacts workspace.",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "clean": "node scripts/clean.mjs",
    "e2e": "vitest run --config vitest.e2e.config.ts --passWithNoTests && node --test e2e/project-install.test.mjs",
    "eval": "vitest run --config vitest.eval.config.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npm run format:check && npm run lint:eslint && npm run type-check",
    "lint:eslint": "eslint .",
    "prepare": "node scripts/prepare-project.mjs",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "type-check": "tsc -b && tsc --project tsconfig.quality.json"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/node": "^24.0.14",
    "eslint": "^9.31.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.36.0",
    "vitest": "^3.2.4"
  }
}
