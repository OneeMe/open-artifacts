{
  "name": "@open-artifacts/decision-board",
  "version": "0.1.0",
  "description": "A high-density decision dashboard with an ECharts signal view.",
  "type": "module",
  "files": [
    "src",
    "input.schema.json",
    "example.json",
    "tsconfig.json",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.tsx",
    "./schema": "./input.schema.json",
    "./example": "./example.json",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "openArtifacts": {
    "format": "react-render/v0"
  },
  "scripts": {
    "build": "tsc -b"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "dependencies": {
    "echarts": "^6.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "typescript": "^5.8.3"
  }
}
